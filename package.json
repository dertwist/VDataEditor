{
  "name": "vdata-editor",
  "productName": "VDataEditor",
  "description": "Desktop editor for Source 2 KV3 data (.vsmart, .vdata, .vpcf, .kv3, …).",
  "keywords": [],
  "main": "./main.js",
  "version": "0.2.0",
  "author": "dertwist",
  "scripts": {
    "start": "electron .",
    "test": "vitest",
    "build:win": "electron-builder --win --publish never"
  },
  "build": {
    "appId": "com.dertwist.vdataeditor",
    "productName": "VDataEditor",
    "fileAssociations": [
      {
        "ext": "vsmart",
        "name": "VData (SmartProp)",
        "description": "Source 2 KV3 / SmartProp",
        "role": "Editor"
      }
    ],
    "files": [
      "**/*",
      "!node_modules/**",
      ".git/**",
      "!dist/**",
      "!*.md"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/images/vdata_editor/appicon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^25.1.8",
    "vitest": "^4.1.0"
  }
}
